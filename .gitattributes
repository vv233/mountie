# Normalise line endings so the repo is consistent regardless of the OS it was
# committed from.
* text=auto

# Shell scripts must keep LF — CRLF breaks the shebang on macOS/Linux
# ("bad interpreter: /usr/bin/env bash^M").
*.sh text eol=lf

# Binary assets git shouldn't try to diff or convert.
*.png binary
*.ico binary
*.icns binary
*.svg text
